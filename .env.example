# ============================================================
# Academic Research Planner — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# LLM Providers
# Gemini + Groq only (free tier access)
# ------------------------------------------------------------
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# ------------------------------------------------------------
# Embeddings
# Cohere Embed v4 — multilingual + text+image in one space
# ------------------------------------------------------------
COHERE_API_KEY=...

# ------------------------------------------------------------
# Vector Store
# QDRANT_API_KEY: leave empty for local Docker instance
# QDRANT_URL: use http://localhost:6333 for local dev
# ------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ------------------------------------------------------------
# Postgres — LangGraph AsyncShallowPostgresSaver
# Format: postgresql+asyncpg://user:password@host:port/dbname
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_planner

# ------------------------------------------------------------
# Web Scraping + Search
# Firecrawl free tier is sufficient for development
# ------------------------------------------------------------
FIRECRAWL_API_KEY=fc-...

# ------------------------------------------------------------
# Observability — LangSmith
# LANGCHAIN_TRACING_V2: set to "false" to disable tracing
# LANGCHAIN_PROJECT: traces grouped under this project name
# ------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=academic-research-planner

# ------------------------------------------------------------
# LLM Model Selection
# Change model strings here — never in logic files.
# Providers: Gemini (reasoning) + Groq (speed)
# ------------------------------------------------------------

# Main agent — strongest reasoning + tool-calling
# IMPORTANT: llama-3.3-70b-versatile has a Groq API tool-calling bug (generates
# <function=...> format that Groq rejects). Use meta-llama/llama-4-scout as primary.
# When Gemini quota resets, swap: gemini-2.0-flash primary, llama-4-scout fallback.
MAIN_AGENT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
MAIN_AGENT_FALLBACK_MODEL=gemini-2.0-flash

# Summarize agent — speed over capability
# Groq primary, Gemini fallback
SUMMARIZE_MODEL=llama-3.1-8b-instant
SUMMARIZE_FALLBACK_MODEL=gemini-2.0-flash-lite

# Deliverable generators — structured output, moderate capability
# llama-4-scout for structured output reliability
DELIVERABLE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
DELIVERABLE_FALLBACK_MODEL=gemini-2.0-flash-lite

# Profiling LLM — runs once at onboarding to seed state
# llama-3.1-8b-instant is fast and sufficient for profiling
PROFILING_MODEL=llama-3.1-8b-instant
PROFILING_FALLBACK_MODEL=gemini-2.0-flash-lite

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------
APP_ENV=development                    # development | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# Token threshold — when to trigger summarize_agent
SUMMARIZE_TOKEN_THRESHOLD=12000

# Tool loop soft cap per turn
MAX_TOOL_ROUNDS=3

# Qdrant collection settings
QDRANT_VECTOR_SIZE=1536             # Cohere Embed v4 output dimension
QDRANT_TOP_K=8                        # chunks returned per query

# Ingestion chunking
CHUNK_TOKEN_SIZE=512
CHUNK_TOKEN_OVERLAP=64

# Profiling — how many chunks to sample for onboarding LLM pass
PROFILING_SAMPLE_CHUNKS=15
